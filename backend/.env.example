NODE_ENV=development
PORT=4000
MONGODB_URI=mongodb://localhost:27017/ecobloom

JWT_SECRET=change-me-to-a-long-random-string
JWT_CUSTOMER_EXPIRES_IN=7d
JWT_ADMIN_EXPIRES_IN=12h

# Used only by `npm run seed:admin` to create the single admin user
ADMIN_EMAIL=info@communn.io
ADMIN_PASSWORD=change-me-strong-password
ADMIN_NAME=EcoBloom Admin

CORS_ORIGINS=http://localhost:8080,http://localhost:8081

UPLOAD_DIR=./uploads
MAX_IMAGE_UPLOAD_MB=10
MAX_VIDEO_UPLOAD_MB=100

# Razorpay test-mode keys (rzp_test_...) — swap for rzp_live_... in production
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# Resend (https://resend.com) — transactional email for booking/welcome/payment notifications.
# Without RESEND_API_KEY set, emails are skipped (logged as a warning) rather than failing requests.
RESEND_API_KEY=
EMAIL_FROM=EcoBloom Plant Care <noreply@ecobloomplantcare.com>
# Where admin-facing notifications (new booking, new payment) get sent — defaults to ADMIN_EMAIL if unset.
ADMIN_NOTIFICATION_EMAIL=
